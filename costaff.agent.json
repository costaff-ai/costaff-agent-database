{
  "name": "costaff-agent-database",
  "version": "0.1.0",
  "description": "[專長] 資料庫管理與跨庫分析。[能力] 支援多種資料庫連線、自動探索 Schema 並執行跨庫查詢與分析。[限制] 僅負責數據提取與結構化結果，不負責數據視覺化排版或報告製作。[產出] 結構化查詢結果 (JSON/CSV)。",
  "a2a_service": "agent-database",
  "port": 8081,
  "env_required": [
    "GOOGLE_API_KEY",
    "DATABASE_CONFIG"
  ],
  "env_optional": [],
  "env_shared": [
    "GOOGLE_API_KEY",
    "COSTAFF_AGENT_MODEL_PROVIDER",
    "LITELLM_MODEL_NAME",
    "LITELLM_API_BASE",
    "LITELLM_API_KEY"
  ],
  "env_auto": [
    "DATABASE_AGENT_MCP_URLS"
  ],
  "model_env_var": "DATABASE_AGENT_MODEL",
  "health_path": "/.well-known/agent.json",
  "mcp_configurable": true,
  "mcp_env_var": "DATABASE_AGENT_MCP_URLS"
}
